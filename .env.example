# Clarifai Environment Configuration
# Copy this file to backend/.env and fill in your actual API keys

# NVIDIA/Brev API Configuration
BREV_NVIDIA_API_KEY=your_brev_nvidia_api_key_here
BREV_NVIDIA_BASE_URL=https://brev.nvidia.com/api

# Other API Keys (to be configured)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
LMNT_API_KEY=your_lmnt_api_key_here
MAGPIE_TTS_API_KEY=your_magpie_tts_api_key_here

# App Configuration
DEBUG=True
ALLOWED_HOSTS=["http://localhost:3000", "http://127.0.0.1:3000"]

# File Storage
MAX_FILE_SIZE=52428800  # 50MB
UPLOAD_DIR=storage
VIDEO_DIR=videos
CLIPS_DIR=clips

# Manim Settings
MANIM_QUALITY=medium_quality